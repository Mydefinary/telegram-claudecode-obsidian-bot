# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OBSIDIAN_VAULT_PATH=E:/your/obsidian/vault

# === Optional: Obsidian ===
# OBSIDIAN_FOLDER=텔레그램

# === Optional: Processing ===
# MAX_CONCURRENT=3
# LANGUAGE=ko

# === Optional: Analysis Engine ===
# Choose one: claude-cli (default), anthropic, openai
# ANALYSIS_ENGINE=claude-cli

# For "anthropic" engine:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For "openai" engine:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# For YouTube analysis via Gemini:
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# For GitHub repo analysis (optional, increases rate limit from 60 to 5000/hr):
# GITHUB_TOKEN=ghp_...

# Claude CLI path (auto-detected if not set)
# CLAUDE_CMD=claude

# === Optional: Message Merge ===
# MESSAGE_MERGE_ENABLED=true
# MESSAGE_MERGE_WAIT=5

# === Security ===
# Comma-separated Telegram user IDs allowed to use this bot (empty = allow all)
# ALLOWED_USER_IDS=123456789,987654321
# MAX_FILE_SIZE=10485760
