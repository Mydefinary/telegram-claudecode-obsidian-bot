# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OBSIDIAN_VAULT_PATH=E:/your/obsidian/vault

# === Optional: Obsidian ===
# OBSIDIAN_FOLDER=텔레그램

# === Optional: Processing ===
# MAX_CONCURRENT=3
# LANGUAGE=ko

# === Optional: Analysis Engine ===
# Choose one: claude-cli (default), anthropic, openai
# ANALYSIS_ENGINE=claude-cli

# For "anthropic" engine:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For "openai" engine:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Claude CLI path (auto-detected if not set)
# CLAUDE_CMD=claude
